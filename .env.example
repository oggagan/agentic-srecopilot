# Copy to .env and fill in. The .env file is gitignored and never committed.

# --- Model (DeepSeek, OpenAI compatible) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# Provider selection: deepseek | anthropic | bedrock
LLM_PROVIDER=deepseek

# --- Fleet access (read only for POC) ---
# The SSH helper that reaches the live box (EC2 Instance Connect).
FLEET_SSH_HELPER=/home/trinity/Downloads/Projects/PersonalSpace/connect-ec2.sh
FLEET_TARGET_HOST=ubuntu@13.206.163.16
FLEET_ENVIRONMENT=prod

# --- Cost guardrail ---
DAILY_MAX_SPEND_USD=2.0

# --- Observability ---
OTEL_ENABLED=true
PHOENIX_ENABLED=true
PHOENIX_OTLP_ENDPOINT=http://localhost:4317
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Database (pgvector RAG + langgraph checkpoints) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/srecopilot

# --- Sandbox EC2 (the only target for writes/remediation) ---
SANDBOX_INSTANCE_ID=
SANDBOX_PEM=
SANDBOX_SSH_USER=ubuntu
AWS_REGION=ap-south-1
AWS_CLI=

# read target for the graph: sandbox (closed loop) or prod (read only demo)
FLEET_READ_TARGET=sandbox
SANDBOX_WRITE_TOKEN_SECRET=
